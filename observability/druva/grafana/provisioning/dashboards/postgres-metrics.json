{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "Postgres Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "pg_up_up", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connections",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 6 },
      "targets": [
        {
          "expr": "pg_database_numbackends",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Commits/sec",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(pg_database_xact_commit[1m])",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rollbacks/sec",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(pg_database_xact_rollback[1m])",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(pg_database_blks_hit[1m]) / (rate(pg_database_blks_hit[1m]) + rate(pg_database_blks_read[1m]))",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Database Size",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "pg_db_size_size",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["postgres-minimal"],
  "time": { "from": "now-15m", "to": "now" },
  "title": "Postgres (Minimal)",
  "version": 1
}