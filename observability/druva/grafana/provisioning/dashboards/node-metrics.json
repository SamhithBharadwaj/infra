{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "timezone": "browser",
  "links": [
    {
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "title": "→ Docker Metrics",
      "tooltip": "Switch to container-level metrics",
      "type": "link",
      "url": "/d/yantra-docker-metrics"
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "At a Glance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "CPU Usage (Now)",
      "description": "Current average CPU utilization per node",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 - (avg by (node) (rate(node_cpu_seconds_total{mode=\"idle\", node=~\"$node\"}[5m])) * 100)",
          "legendFormat": "{{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Memory Usage (Now)",
      "description": "Current memory utilization per node",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{node=~\"$node\"} / node_memory_MemTotal_bytes{node=~\"$node\"}) * 100",
          "legendFormat": "{{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Uptime",
      "description": "Time since last boot per node",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "green", "value": 86400 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{node=~\"$node\"}",
          "legendFormat": "{{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "title": "CPU Usage %",
      "description": "CPU utilization over time per node (5m rolling average). Threshold lines at 60% and 85%.",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": {
            "fillOpacity": 12,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "100 - (avg by (node) (rate(node_cpu_seconds_total{mode=\"idle\", node=~\"$node\"}[5m])) * 100)",
          "legendFormat": "{{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "System Load (1m / 5m / 15m)",
      "description": "System load average at 1m (red), 5m (orange), and 15m (blue) intervals",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 0, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".* — 1m$" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "semi-dark-red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".* — 5m$" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "semi-dark-orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".* — 15m$" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "semi-dark-blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "node_load1{node=~\"$node\"}",
          "legendFormat": "{{ node }} — 1m",
          "refId": "A"
        },
        {
          "expr": "node_load5{node=~\"$node\"}",
          "legendFormat": "{{ node }} — 5m",
          "refId": "B"
        },
        {
          "expr": "node_load15{node=~\"$node\"}",
          "legendFormat": "{{ node }} — 15m",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "title": "Memory",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "Memory Usage %",
      "description": "Memory utilization percentage over time per node. Threshold lines at 70% and 90%.",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "custom": {
            "fillOpacity": 12,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{node=~\"$node\"} / node_memory_MemTotal_bytes{node=~\"$node\"}) * 100",
          "legendFormat": "{{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Memory Used (bytes)",
      "description": "Absolute memory used vs total per node. Dashed red line = total capacity.",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 12, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".* — total$" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "color", "value": { "fixedColor": "semi-dark-red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{node=~\"$node\"} - node_memory_MemAvailable_bytes{node=~\"$node\"}",
          "legendFormat": "{{ node }} — used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes{node=~\"$node\"}",
          "legendFormat": "{{ node }} — total",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "title": "Disk",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 12,
      "title": "Disk Usage %",
      "description": "Current disk space utilization per mount point. Yellow ≥ 70%, Red ≥ 90%.",
      "type": "bargauge",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{node=~\"$node\", mountpoint=~\"$mountpoint\", fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{node=~\"$node\", mountpoint=~\"$mountpoint\", fstype!~\"tmpfs|overlay\"}) * 100",
          "legendFormat": "{{ node }} {{ mountpoint }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Disk I/O (bytes/s)",
      "description": "Block device read (blue) and write (orange) throughput per node",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".* — read$" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "semi-dark-blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".* — write$" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "semi-dark-orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{node=~\"$node\"}[5m])",
          "legendFormat": "{{ node }} — read",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{node=~\"$node\"}[5m])",
          "legendFormat": "{{ node }} — write",
          "refId": "B"
        }
      ]
    },
    {
      "id": 14,
      "title": "Network",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 15,
      "title": "Network Traffic (bytes/s)",
      "description": "Inbound receive (green) and outbound transmit (orange) throughput per node and interface",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".* — rx$" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "semi-dark-green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".* — tx$" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "semi-dark-orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{node=~\"$node\", device=~\"eth.*|enp.*|wlan.*\"}[5m])",
          "legendFormat": "{{ node }} {{ device }} — rx",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{node=~\"$node\", device=~\"eth.*|enp.*|wlan.*\"}[5m])",
          "legendFormat": "{{ node }} {{ device }} — tx",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["node", "infrastructure"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "definition": "label_values(node_uname_info, node)",
        "includeAll": true,
        "multi": true,
        "name": "node",
        "query": "label_values(node_uname_info, node)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "definition": "label_values(node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"}, mountpoint)",
        "includeAll": true,
        "multi": true,
        "name": "mountpoint",
        "query": "label_values(node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"}, mountpoint)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Node Metrics",
  "uid": "yantra-node-metrics"
}
