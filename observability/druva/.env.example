# Grafana admin password
GRAFANA_ADMIN_PASSWORD=changeme

# Docker data path on druva (symlinked from /var/lib/docker)
DOCKER_LOG_PATH=/mnt/storage/docker

# Remote node IPs — used in prometheus/targets/*.json
# Update these after deploying agents on each node
IDEAPAD_IP=192.168.1.x
PROXMOX_NOGPU_IP=192.168.1.x
PROXMOX_GPU_IP=192.168.1.x
