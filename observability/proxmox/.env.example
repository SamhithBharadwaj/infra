# Loki endpoint on druva (central stack)
LOKI_URL=http://druva:3100/loki/api/v1/push

# This node's hostname — change per VM:
#   proxmox-nogpu  (Ubuntu Server VM without GPU)
#   proxmox-gpu    (Ubuntu Server VM with GPU passthrough)
NODE_HOSTNAME=proxmox-nogpu

# Docker data path (default location on Proxmox VMs)
DOCKER_LOG_PATH=/var/lib/docker
